CREATE DATABASE CAC;
GO

USE CAC;
GO

CREATE TABLE analistas (
    id INT IDENTITY(1,1) PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    orden INT NOT NULL,
    activo BIT NOT NULL DEFAULT 1,
    IdHorario INT NULL,
    existe BIT NOT NULL DEFAULT 1
);

CREATE TABLE Horarios
(
    id INT IDENTITY(1,1) PRIMARY KEY,

    HoraEntrada TIME NOT NULL,
    HoraSalida TIME NOT NULL,

    HoraAlmuerzoInicio TIME NULL,
    HoraAlmuerzoFin TIME NULL
);

CREATE TABLE casos3cx (
    id INT IDENTITY(1,1) PRIMARY KEY,
    idAnalista INT NOT NULL,
    numerochat BIGINT NOT NULL,
    fecha DATETIME NOT NULL DEFAULT GETDATE(),

    CONSTRAINT FK_casos3cx_analistas
    FOREIGN KEY (idAnalista) REFERENCES analistas(id)
);

CREATE TABLE estaciones (
    id INT IDENTITY(1,1) PRIMARY KEY,
    nombre VARCHAR(150) NOT NULL,
    existe BIT NOT NULL DEFAULT 1
);

CREATE TABLE casosAA (
    id INT IDENTITY(1,1) PRIMARY KEY,
    idAnalista INT NOT NULL,
    idnombreEDS INT NOT NULL,
    fecha DATETIME NOT NULL DEFAULT GETDATE(),

    CONSTRAINT FK_casosAA_analistas
    FOREIGN KEY (idAnalista) REFERENCES analistas(id),

    CONSTRAINT FK_casosAA_estaciones
    FOREIGN KEY (idnombreEDS) REFERENCES estaciones(id)
);

CREATE TABLE tiposCaso (
    id INT IDENTITY(1,1) PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL,
    activo BIT NOT NULL DEFAULT 1
);

CREATE TABLE categorias (
    id INT IDENTITY(1,1) PRIMARY KEY,
    nombre VARCHAR(100) NOT NULL,
    activo BIT NOT NULL DEFAULT 1
);

CREATE TABLE tickets (
    id INT IDENTITY(1,1) PRIMARY KEY,

    casoAtendido VARCHAR(500) NOT NULL,
    EDS VARCHAR(200) NOT NULL,

    idTipoCaso INT NOT NULL,
    idCategoria INT NOT NULL,

    origenFalla VARCHAR(MAX) NOT NULL,
    solucion VARCHAR(MAX) NOT NULL,

    idAnalista INT NOT NULL,

    fechaHora DATETIME NOT NULL DEFAULT GETDATE(),

    tiempoAtencionMin INT NOT NULL, -- 🔥 Guardado en minutos

    versiones VARCHAR(200) NULL,
    observaciones VARCHAR(MAX) NULL,

    CONSTRAINT FK_tickets_analista
    FOREIGN KEY (idAnalista) REFERENCES analistas(id),

    CONSTRAINT FK_tickets_tipoCaso
    FOREIGN KEY (idTipoCaso) REFERENCES tiposCaso(id),

    CONSTRAINT FK_tickets_categoria
    FOREIGN KEY (idCategoria) REFERENCES categorias(id)
);


